{
  "name": "maam",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:docker": "docker build -t maam . && mkdir -p dist && docker save -o dist/maam.tar maam",
    "start": "pnpm -F @maam/server start",
    "start:docker": "docker run -p 3113:3113 maam",
    "lint": "eslint",
    "lint:fix": "eslint --fix .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "ci": "pnpm build && pnpm lint && pnpm typecheck && pnpm test",
    "maam": "git pull && pnpm install --frozen-lockfile && pnpm build && pnpm start"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^2.4.0",
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20251204.1",
    "@vitest/eslint-plugin": "^1.6.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^16.5.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.50.1",
    "vite": "npm:rolldown-vite@7.1.20",
    "vitest": "^4.0.16"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "bash -c 'tsgo -b --noEmit'",
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.26.2+sha512.0e308ff2005fc7410366f154f625f6631ab2b16b1d2e70238444dd6ae9d630a8482d92a451144debc492416896ed16f7b114a86ec68b8404b2443869e68ffda6"
}
