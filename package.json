{
  "name": "maam",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:docker": "docker build -t maam . && mkdir -p dist && docker save -o dist/maam.tar maam",
    "start": "pnpm -F @maam/server start",
    "start:test": "pnpm -F @maam/server start:test",
    "start:docker": "docker run -p 3113:3113 maam",
    "lint": "eslint",
    "lint:fix": "eslint --fix .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci": "pnpm build && pnpm lint && pnpm typecheck && pnpm test",
    "maam": "git pull && pnpm install --frozen-lockfile && pnpm build && pnpm start"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^2.1.1",
    "@eslint/compat": "^1.4.0",
    "@eslint/js": "^9.37.0",
    "@playwright/test": "^1.56.1",
    "@types/node": "^22.18.10",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/browser": "^4.0.5",
    "@vitest/browser-playwright": "^4.0.5",
    "@vitest/browser-preview": "^4.0.5",
    "@vitest/eslint-plugin": "^1.3.20",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-unused-imports": "^4.2.0",
    "globals": "^16.4.0",
    "lint-staged": "^16.2.4",
    "playwright": "^1.56.1",
    "prettier": "^3.6.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.0",
    "vite": "npm:rolldown-vite@7.1.20",
    "vitest": "^4.0.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "bash -c 'tsc -b --noEmit'",
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.20.0+sha512.cf9998222162dd85864d0a8102e7892e7ba4ceadebbf5a31f9c2fce48dfce317a9c53b9f6464d1ef9042cba2e02ae02a9f7c143a2b438cd93c91840f0192b9dd"
}
