{
  "name": "@maam/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node ./dist/server.js",
    "test": "vitest run",
    "typecheck": "tsgo -b --noEmit",
    "drizzle": "drizzle-kit"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./const": {
      "import": "./src/const.ts",
      "types": "./src/const.ts"
    },
    "./schema": {
      "import": "./src/lib/schema.ts",
      "types": "./src/lib/schema.ts"
    },
    "./db/schema": {
      "import": "./src/lib/db/schema.ts",
      "types": "./src/lib/db/schema.ts"
    },
    "./lib/temporal": {
      "import": "./src/lib/temporal.ts",
      "types": "./src/lib/temporal.ts"
    }
  },
  "dependencies": {
    "@hono/arktype-validator": "^2.0.1",
    "@hono/node-server": "^1.19.13",
    "@orpc/server": "^1.12.2",
    "@tanstack/pacer": "^0.17.0",
    "arkenv": "^0.7.6",
    "arkregex": "^0.0.4",
    "arktype": "^2.1.28",
    "better-sqlite3": "^12.5.0",
    "cheerio": "^1.1.2",
    "drizzle-arktype": "^0.1.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "minimatch": "10.2.4",
    "munkres": "^2.0.4",
    "rotating-file-stream": "^3.2.7",
    "sharp": "^0.34.5",
    "temporal-polyfill": "^0.3.0",
    "toad-scheduler": "^3.1.0",
    "tslog": "^4.10.2"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0.23.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@typescript/native-preview": "7.0.0-dev.20251204.1",
    "drizzle-kit": "^0.31.8",
    "typescript": "~5.9.3",
    "vite": "npm:rolldown-vite@7.1.20"
  }
}
